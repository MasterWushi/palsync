# dependencies
node_modules/

# logs
*.log

# secrets / credentials — never commit
.palpushrc
.env
.env.*
*.pem
*.key
secrets.json

# per-workspace sync state (generated by the launcher; may name a cloud/user)
.palsync.json
.mcp.json

# pulled pal data — real client/dataset content; must never ship
.pals/
*PAL_BACKUP*
ISR_PAL_BACKUP/

# local / temporary pal workspaces and test output
tmp/
temp/
*.tmp
*-workspace/
.DS_Store

# internal: editor config, verification scripts, internal specs — not part of the public tool
.claude/
scripts/
SPEC_*
